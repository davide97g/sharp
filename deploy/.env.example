# sharp deployment configuration — copy to .env and edit.
#   cp .env.example .env

# --- Secrets (CHANGE THESE) -------------------------------------------------
# Postgres password for the `sharp` database user.
POSTGRES_PASSWORD=change-me-strong

# JWT signing secret (HS256). Use 64+ random chars, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-64-random-chars

# --- Domains & TLS ----------------------------------------------------------
# Where the chat app is served (Caddy reverse-proxies this to sharp:3000).
SHARP_DOMAIN=chat.example.com
# Where the static landing page is served.
LANDING_DOMAIN=example.com
# Email used for Let's Encrypt / ACME registration.
ACME_EMAIL=you@example.com

# --- App behaviour ----------------------------------------------------------
# Set to true after onboarding to close public registration.
SHARP_DISABLE_SIGNUP=false

# tldraw commercial license key — removes the watermark on the canvas.
# Inlined into the public web bundle at build time (not a secret). The compose
# file already defaults to the current key; set this only to override/rotate it.
TLDRAW_LICENSE_KEY=

# Log verbosity (error|warn|info|debug|trace).
RUST_LOG=info
