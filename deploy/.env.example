# sharp deployment configuration — copy to .env and edit.
#   cp .env.example .env

# --- Secrets (CHANGE THESE) -------------------------------------------------
# Postgres password for the `sharp` database user.
POSTGRES_PASSWORD=change-me-strong

# JWT signing secret (HS256). Use 64+ random chars, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-64-random-chars

# --- Domains & TLS ----------------------------------------------------------
# Where the chat app is served (Caddy reverse-proxies this to sharp:3000).
SHARP_DOMAIN=chat.example.com
# Where the static landing page is served.
LANDING_DOMAIN=example.com
# Email used for Let's Encrypt / ACME registration.
ACME_EMAIL=you@example.com

# LiveKit SFU hostname and signing credentials. Generate each secret with
# `openssl rand -hex 32`. TURN/TLS uses 5349 because Caddy owns port 443.
MEDIA_DOMAIN=media.example.com
LIVEKIT_API_KEY=sharp-livekit
LIVEKIT_API_SECRET=change-me-livekit-64-random-chars
# Absolute host paths to a trusted certificate/key for MEDIA_DOMAIN. Renew them
# before expiry, then restart the livekit container so TURN/TLS reloads them.
LIVEKIT_TURN_CERT_FILE=/etc/letsencrypt/live/media.example.com/fullchain.pem
LIVEKIT_TURN_KEY_FILE=/etc/letsencrypt/live/media.example.com/privkey.pem

# --- App behaviour ----------------------------------------------------------
# Set to true after onboarding to close public registration.
SHARP_DISABLE_SIGNUP=false

# Optional passkeys/WebAuthn. Keep RP_ID stable after first enrollment.
# For same-origin deployment, use SHARP_DOMAIN as RP_ID and https://SHARP_DOMAIN as origin.
# Split deployments may list multiple exact origins, comma-separated.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGINS=
WEBAUTHN_RP_NAME=Sharp

# tldraw commercial license key — removes the watermark on the canvas.
# Inlined into the public web bundle at build time (not a secret). The compose
# file already defaults to the current key; set this only to override/rotate it.
TLDRAW_LICENSE_KEY=

# --- Sharpy AI assistant (optional) -----------------------------------------
# OpenAI-compatible provider for the workspace AI assistant + semantic search.
# Leave AI_API_KEY empty to disable the feature entirely.
# Works with OpenAI, DeepSeek, Ollama (http://host:11434/v1), LM Studio, etc.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small

# Log verbosity (error|warn|info|debug|trace).
RUST_LOG=info
