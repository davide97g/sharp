# sharp landing page — static Astro build served by nginx.
# Build context must be the REPO ROOT:
#   docker build -f deploy/Dockerfile.landing .

FROM oven/bun:1-alpine AS build
WORKDIR /landing
COPY landing/package.json landing/bun.lock* ./
RUN bun install --frozen-lockfile || bun install
COPY landing/ ./
RUN bun run build

FROM nginx:alpine
COPY --from=build /landing/dist /usr/share/nginx/html
EXPOSE 80
