{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sharp",
  "version": "0.1.0",
  "identifier": "dev.sharp.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun --cwd ../web run dev",
    "beforeBuildCommand": "bun --cwd ../web run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sharp",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sharp"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
