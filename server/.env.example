# Copy to .env for local development: cp .env.example .env
DATABASE_URL=postgres://sharp:sharp@localhost:5432/sharp
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
PORT=3000
SHARP_DISABLE_SIGNUP=false
RUST_LOG=info
# WEB_DIST=../web/dist

# --- File uploads (S3-compatible: AWS S3, MinIO, Cloudflare R2, Backblaze B2) ---
# Uploads are enabled only when BUCKET + ACCESS_KEY + SECRET_KEY are all set.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=sharp
S3_ACCESS_KEY=sharp
S3_SECRET_KEY=sharp-secret
S3_REGION=us-east-1
# Allow plaintext http (auto-on when S3_ENDPOINT starts with http://; set for MinIO):
S3_ALLOW_HTTP=true
# Max upload size in MB (default 25):
# MAX_UPLOAD_MB=25

# --- Web push (VAPID) ---
# Leave unset to auto-generate + persist a keypair on first startup (recommended
# for self-hosting). To pin your own, generate with `npx web-push generate-vapid-keys`
# and set both (VAPID_PRIVATE_KEY is the raw base64url private key, not a PEM):
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@sharp.app

# GIPHY API key used by GIF search when no workspace key is saved (default provider).
# GIPHY_API_KEY=
# Tenor v2 API key for legacy clients; Tenor no longer accepts new API clients.
# TENOR_API_KEY=
# DeepSeek API key used by automatic GIF suggestions.
# DEEPSEEK_API_KEY=
# DeepSeek chat model (default: deepseek-chat).
# DEEPSEEK_MODEL=deepseek-chat
# DeepSeek API base URL (default: https://api.deepseek.com).
# DEEPSEEK_BASE_URL=https://api.deepseek.com
