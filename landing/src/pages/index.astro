---
import "../styles/global.css";

const GITHUB_OWNER = "davide97g";
const repo = `https://github.com/${GITHUB_OWNER}/sharp`;
const releases = `${repo}/releases/latest`;

const title = "sharp — Team chat, docs, canvas, calls & tasks. Your server. No compromises.";
const description =
  "An open-source, self-hosted Slack replacement: channels, threads, DMs, collaborative docs and canvas, voice/video calls, a Linear-lite task tracker with GitHub sync, file uploads and full-text search — running on your own server from a single container.";
const siteUrl = "https://sharp.davideghiotto.it";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={siteUrl} />
    <meta name="theme-color" content="#0e0e11" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="sharp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body>
    <!-- Animated gradient orbs -->
    <div class="gradient-orb orb-1" aria-hidden="true"></div>
    <div class="gradient-orb orb-2" aria-hidden="true"></div>
    <div class="gradient-orb orb-3" aria-hidden="true"></div>

    <!-- Floating particles -->
    <div class="particles" id="particles" aria-hidden="true"></div>

    <!-- ===== Nav ===== -->
    <nav class="nav" id="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">
          <span class="hash">#</span> sharp
        </a>
        <div class="nav-links">
          <a class="hide-sm" href="#features">Features</a>
          <a class="hide-sm" href="#tasks">Tasks</a>
          <a class="hide-sm" href="#selfhost">Self-host</a>
          <a class="hide-sm" href="#download">Download</a>
          <a class="gh" href={repo} rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5Z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- ===== Hero ===== -->
    <header class="hero" id="hero">
      <div class="hero-glow" id="heroGlow" aria-hidden="true"></div>
      <div class="container">
        <div class="mark reveal"><span>#</span></div>
        <div class="reveal" style="transition-delay:0.1s">
          <span class="pill"><span class="dot"></span> Open source · AGPL-3.0 · self-hosted</span>
        </div>
        <h1 class="headline reveal" style="transition-delay:0.2s">
          <span id="headlineText">Chat, docs, canvas, calls &amp; tasks. Your server.</span><span class="typing-cursor"></span>
        </h1>
        <p class="subline reveal" style="transition-delay:0.3s">
          sharp is an open-source Slack replacement — channels, threads and DMs,
          real-time collaborative docs and canvas, voice/video calls with screen
          sharing, a Linear-lite task tracker, file uploads and full-text search —
          self-hosted in a single container. Your data never leaves your infrastructure.
        </p>
        <div class="cta-row reveal" style="transition-delay:0.4s">
          <a id="downloadCta" class="btn btn-primary" href={releases} rel="noopener">
            Download for macOS
          </a>
          <a class="btn btn-ghost" href="#selfhost">Self-host in 5 minutes</a>
        </div>
        <p class="cta-note reveal" style="transition-delay:0.45s">No account. No telemetry. No SaaS lock-in.</p>

        <!-- ===== App mock with 3D tilt ===== -->
        <div class="mock-wrap reveal" style="transition-delay:0.5s">
          <div class="mock" id="mockTilt">
            <div class="mock-bar">
              <span class="tl"></span><span class="tl"></span><span class="tl"></span>
              <span class="title">sharp — #general</span>
            </div>
            <div class="mock-body">
              <aside class="mock-side">
                <div class="side-ws"><span class="hash">#</span> Acme Inc</div>
                <div class="side-label">Channels</div>
                <div class="side-item active"><span class="h">#</span> general</div>
                <div class="side-item"><span class="h">#</span> engineering <span class="badge">3</span></div>
                <div class="side-item"><span class="h">#</span> design</div>
                <div class="side-item"><span class="h">#</span> random</div>
                <div class="side-label">Pages</div>
                <div class="side-item"><span class="h">¶</span> Launch plan</div>
                <div class="side-item"><span class="h">◈</span> Architecture canvas</div>
                <div class="side-label">Direct messages</div>
                <div class="side-item">Jordan Lee <span class="pdot"></span></div>
                <div class="side-item">Priya Shah <span class="pdot"></span></div>
              </aside>
              <main class="mock-main">
                <div class="chan-head">
                  # general
                  <span class="topic">— company-wide announcements &amp; watercooler</span>
                </div>
                <div class="msgs">
                  <div class="msg">
                    <div class="avatar" style="background:#7c6cff">JL</div>
                    <div class="msg-body">
                      <div class="msg-head"><span class="name">Jordan Lee</span><span class="time">9:41 AM</span></div>
                      <div class="msg-text">morning team — shipping the v1 release today. self-hosted, one container, zero drama.</div>
                      <div class="reacts"><span class="react on">🚀 4</span><span class="react">🎉 2</span></div>
                    </div>
                  </div>
                  <div class="msg">
                    <div class="avatar" style="background:#3ddc84">PS</div>
                    <div class="msg-body">
                      <div class="msg-head"><span class="name">Priya Shah</span><span class="time">9:43 AM</span></div>
                      <div class="msg-text">love it. moved our whole workspace over the weekend, Postgres backup was painless.</div>
                      <div class="thread-link">↳ 3 replies · last today at 9:52 AM</div>
                    </div>
                  </div>
                  <div class="msg">
                    <div class="avatar" style="background:#ff8a5c">MK</div>
                    <div class="msg-body">
                      <div class="msg-head"><span class="name">Mika K</span><span class="time">9:50 AM</span></div>
                      <div class="msg-text">
                        search across every channel is instant now 🔍 @jordan
                        wrote it all up in <span class="docchip">¶ Launch plan</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="composer">Message #general — Enter to send, Shift+Enter for newline</div>
              </main>
              <aside class="mock-thread">
                <div class="thread-head">Thread <span>· 3 replies</span></div>
                <div class="msg" style="margin-bottom:14px">
                  <div class="avatar" style="width:30px;height:30px;font-size:12px;background:#3ddc84">PS</div>
                  <div class="msg-body">
                    <div class="msg-head"><span class="name">Priya Shah</span></div>
                    <div class="msg-text">which VPS did you land on?</div>
                  </div>
                </div>
                <div class="msg">
                  <div class="avatar" style="width:30px;height:30px;font-size:12px;background:#7c6cff">JL</div>
                  <div class="msg-body">
                    <div class="msg-head"><span class="name">Jordan Lee</span></div>
                    <div class="msg-text">a $6 box. Caddy does TLS, done.</div>
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- ===== Stats ===== -->
    <section id="stats">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item reveal" style="transition-delay:0s">
            <div class="stat-number"><span class="count-up" data-target="100">0</span>%</div>
            <div class="stat-label">Open source · AGPL-3.0</div>
          </div>
          <div class="stat-item reveal" style="transition-delay:0.1s">
            <div class="stat-number"><span class="count-up" data-target="1">0</span></div>
            <div class="stat-label">Container to deploy</div>
          </div>
          <div class="stat-item reveal" style="transition-delay:0.2s">
            <div class="stat-number"><span class="count-up" data-target="0">0</span></div>
            <div class="stat-label">Telemetry · Zero tracking</div>
          </div>
          <div class="stat-item reveal" style="transition-delay:0.3s">
            <div class="stat-number"><span class="count-up" data-target="3">0</span></div>
            <div class="stat-label">Desktop platforms</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Features ===== -->
    <section id="features">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Why sharp</div>
          <h2>One workspace. Chat, docs, canvas, calls &amp; tasks.</h2>
          <p>Everything a team needs to talk, write, draw, meet and ship — and nothing that phones home.</p>
        </div>
        <div class="features stagger" id="featuresGrid">
          <div class="card">
            <div class="icon">#</div>
            <h3>Sharp chat</h3>
            <ul>
              <li>Threads that keep replies out of the way</li>
              <li>@mentions &amp; emoji reactions</li>
              <li>Public channels, private groups &amp; DMs</li>
              <li>@people &amp; #resource autocomplete in the composer</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">¶</div>
            <h3>Collaborative docs</h3>
            <ul>
              <li>Block-based docs live inside any channel</li>
              <li>Real-time co-editing, cursors &amp; presence</li>
              <li>Per-doc roles &amp; live sharing controls</li>
              <li><code>[[doc]]</code> links bridge chat &amp; docs</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">◈</div>
            <h3>Shared canvas</h3>
            <ul>
              <li>Infinite whiteboards powered by tldraw</li>
              <li>Sketch, diagram &amp; brainstorm together live</li>
              <li>Same roles &amp; sharing model as docs</li>
              <li>One click from any channel</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">◉</div>
            <h3>Voice, video &amp; screen share</h3>
            <ul>
              <li>P2P WebRTC calls in any channel or DM</li>
              <li>Webcam video &amp; screen sharing with audio</li>
              <li>Picture-in-picture keeps the call floating</li>
              <li>Guest links — join by name, no account</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">⌕</div>
            <h3>Files &amp; search</h3>
            <ul>
              <li>Drag-and-drop uploads, images inline</li>
              <li>Instant Postgres full-text search</li>
              <li>Files on your own S3/MinIO storage</li>
              <li>Nothing ever leaves your infrastructure</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">◔</div>
            <h3>Never miss a mention</h3>
            <ul>
              <li>Unified mention inbox across chat, docs &amp; canvas</li>
              <li>Web push + native OS notifications</li>
              <li>Per-channel mute &amp; do-not-disturb</li>
              <li>Toasts while you work, push while away</li>
            </ul>
          </div>
          <div class="card">
            <div class="icon">⌂</div>
            <h3>Yours, everywhere</h3>
            <ul>
              <li>Self-host in one container, plain Postgres</li>
              <li>AGPL-3.0 · zero telemetry, zero tracking</li>
              <li>Web app in any modern browser</li>
              <li>Native macOS, Windows &amp; Linux via Tauri</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Tasks (Linear-lite) ===== -->
    <section id="tasks" class="tasks-section">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Tasks</div>
          <h2>Linear-lite, built in.</h2>
          <p>
            A native issue tracker for the same workspace — projects, workflow states,
            list &amp; board views, chat bridging, and GitHub sync. No third-party SaaS.
          </p>
        </div>

        <div class="tasks-layout">
          <div class="tasks-copy reveal-left">
            <ul class="tasks-points">
              <li>
                <strong>Projects &amp; identifiers</strong>
                <span><code>SHARP-123</code> keys allocate from a sequence. Dense list rows or a state board — your call.</span>
              </li>
              <li>
                <strong>Create from chat</strong>
                <span>Turn a message into a task. Bare identifiers auto-linkify; chips deep-link back.</span>
              </li>
              <li>
                <strong>GitHub sync</strong>
                <span>Branch &amp; PR names move state for you — started on open, completed on merge.</span>
              </li>
              <li>
                <strong>Keyboard-first</strong>
                <span>Peek panel, property pickers, <code>c</code> to create. Same muscle memory as Linear.</span>
              </li>
            </ul>
          </div>

          <div class="tasks-mock reveal-right" aria-hidden="true">
            <div class="tm-bar">
              <span class="tm-proj"><span class="tm-key">SHARP</span> Engineering</span>
              <span class="tm-views"><span class="on">List</span><span>Board</span></span>
            </div>
            <div class="tm-group">
              <div class="tm-group-head"><span class="tm-dot started"></span> In Progress <em>3</em></div>
              <div class="tm-row active">
                <span class="tm-pri high" title="High"></span>
                <span class="tm-id">SHARP-128</span>
                <span class="tm-title">Wire GitHub webhook state automation</span>
                <span class="tm-label">backend</span>
                <span class="tm-avatar" style="background:#7c6cff">JL</span>
              </div>
              <div class="tm-row">
                <span class="tm-pri urgent" title="Urgent"></span>
                <span class="tm-id">SHARP-124</span>
                <span class="tm-title">Task peek: comments + activity feed</span>
                <span class="tm-label">web</span>
                <span class="tm-avatar" style="background:#ff8a5c">MK</span>
              </div>
              <div class="tm-row">
                <span class="tm-pri med" title="Medium"></span>
                <span class="tm-id">SHARP-119</span>
                <span class="tm-title">Create task from message toolbar</span>
                <span class="tm-label">chat</span>
                <span class="tm-avatar" style="background:#3ddc84">PS</span>
              </div>
            </div>
            <div class="tm-group">
              <div class="tm-group-head"><span class="tm-dot todo"></span> Todo <em>2</em></div>
              <div class="tm-row">
                <span class="tm-pri none" title="No priority"></span>
                <span class="tm-id">SHARP-131</span>
                <span class="tm-title">Sharpy embeddings for task titles</span>
                <span class="tm-label">ai</span>
                <span class="tm-due">Fri</span>
              </div>
              <div class="tm-row">
                <span class="tm-pri low" title="Low"></span>
                <span class="tm-id">SHARP-132</span>
                <span class="tm-title">Filter bar: assignee + label + priority</span>
                <span class="tm-label">web</span>
                <span class="tm-due">Mon</span>
              </div>
            </div>
            <div class="tm-peek">
              <div class="tm-peek-id">SHARP-128</div>
              <div class="tm-peek-title">Wire GitHub webhook state automation</div>
              <div class="tm-props">
                <div><span>Status</span><strong><i class="tm-dot started"></i> In Progress</strong></div>
                <div><span>Priority</span><strong>High</strong></div>
                <div><span>Assignee</span><strong>Jordan Lee</strong></div>
                <div><span>GitHub</span><strong class="tm-gh">davide97g/sharp#128</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Self-host ===== -->
    <section id="selfhost" class="selfhost">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Self-host</div>
          <h2>Up and running in 5 minutes</h2>
          <p>One container plus Postgres. Copy, paste, and you own your team's chat.</p>
        </div>
        <div class="code-block reveal-scale">
          <div class="code-top">
            <span class="label">bash</span>
            <button id="copyBtn" class="copy-btn" type="button">Copy</button>
          </div>
          <pre><code id="codeText"><span class="cmd">git clone</span> {repo} \
  && <span class="cmd">cd</span> sharp/deploy \
  && <span class="cmd">cp</span> .env.example .env \
  && <span class="cmd">docker compose</span> up -d</code></pre>
        </div>
        <div class="steps">
          <div class="step reveal" style="transition-delay:0.1s"><span class="n">1</span> Point DNS at your box</div>
          <div class="step reveal" style="transition-delay:0.2s"><span class="n">2</span> Set secrets in <code>.env</code></div>
          <div class="step reveal" style="transition-delay:0.3s"><span class="n">3</span> Register the first account</div>
        </div>
      </div>
    </section>

    <!-- ===== Download ===== -->
    <section id="download">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">Download</div>
          <h2>Get the desktop app</h2>
          <p>Native builds for every platform. Point it at your server URL and sign in.</p>
        </div>
        <div class="dl-grid stagger" id="dlGrid">
          <div class="dl-card">
            <div class="os">🍎</div>
            <h3>macOS</h3>
            <p>Apple Silicon &amp; Intel · .dmg</p>
            <a class="btn btn-primary" href={releases} rel="noopener">Download</a>
          </div>
          <div class="dl-card">
            <div class="os">🪟</div>
            <h3>Windows</h3>
            <p>64-bit installer · .exe</p>
            <a class="btn btn-ghost" href={releases} rel="noopener">Download</a>
          </div>
          <div class="dl-card">
            <div class="os">🐧</div>
            <h3>Linux</h3>
            <p>AppImage &amp; .deb</p>
            <a class="btn btn-ghost" href={releases} rel="noopener">Download</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Footer ===== -->
    <footer>
      <div class="container footer-inner">
        <a class="brand" href="/"><span class="hash" style="color:var(--accent)">#</span> sharp</a>
        <div class="footer-links">
          <a href={repo} rel="noopener">GitHub</a>
          <a href={`${repo}/blob/main/LICENSE`} rel="noopener">AGPL-3.0</a>
          <a href="#selfhost">Self-host</a>
          <a href="#download">Download</a>
        </div>
        <div>Built in the open.</div>
      </div>
    </footer>

    <!-- ===== Master JS: reveals, tilt, particles, count-up, glow ===== -->
    <script is:inline>
      (function () {
        "use strict";

        /* ── OS detect for CTA ── */
        (function () {
          var cta = document.getElementById("downloadCta");
          if (cta) {
            var ua = navigator.userAgent || "";
            var os = "macOS";
            if (/Windows/i.test(ua)) os = "Windows";
            else if (/Linux|X11/i.test(ua) && !/Android/i.test(ua)) os = "Linux";
            else if (/Mac/i.test(ua)) os = "macOS";
            cta.textContent = "Download for " + os;
          }
        })();

        /* ── Copy button ── */
        (function () {
          var btn = document.getElementById("copyBtn");
          var code = document.getElementById("codeText");
          if (btn && code) {
            btn.addEventListener("click", function () {
              var text = code.innerText.replace(/\s+\\\s+/g, " ").trim();
              navigator.clipboard.writeText(text).then(function () {
                btn.textContent = "Copied!";
                btn.classList.add("copied");
                setTimeout(function () {
                  btn.textContent = "Copy";
                  btn.classList.remove("copied");
                }, 2000);
              });
            });
          }
        })();

        /* ── Floating particles ── */
        (function () {
          var container = document.getElementById("particles");
          if (!container) return;
          var count = 30;
          for (var i = 0; i < count; i++) {
            var p = document.createElement("div");
            p.className = "particle";
            var size = 2 + Math.random() * 3;
            p.style.width = size + "px";
            p.style.height = size + "px";
            p.style.left = Math.random() * 100 + "%";
            p.style.animationDuration = (15 + Math.random() * 25) + "s";
            p.style.animationDelay = (Math.random() * 20) + "s";
            var colors = ["rgba(124,108,255,", "rgba(79,209,232,", "rgba(255,107,166,"];
            var c = colors[Math.floor(Math.random() * colors.length)];
            p.style.background = c + (0.2 + Math.random() * 0.4) + ")";
            container.appendChild(p);
          }
        })();

        /* ── Scroll reveal via IntersectionObserver ── */
        (function () {
          var els = document.querySelectorAll(".reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger");
          if (!els.length) return;
          var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });
          els.forEach(function (el) { obs.observe(el); });
        })();

        /* ── Nav scroll shadow ── */
        (function () {
          var nav = document.getElementById("nav");
          if (!nav) return;
          var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              nav.classList.toggle("scrolled", !entry.isIntersecting);
            });
          }, { threshold: 0 });
          var sentinel = document.createElement("div");
          sentinel.style.position = "absolute";
          sentinel.style.top = "0";
          sentinel.style.left = "0";
          sentinel.style.width = "1px";
          sentinel.style.height = "1px";
          sentinel.style.opacity = "0";
          document.body.prepend(sentinel);
          obs.observe(sentinel);
        })();

        /* ── 3D tilt on mock ── */
        (function () {
          var mock = document.getElementById("mockTilt");
          if (!mock) return;
          var wrap = mock.parentElement;
          var isMobile = window.innerWidth < 860;
          if (isMobile) return;

          wrap.addEventListener("mousemove", function (e) {
            var rect = wrap.getBoundingClientRect();
            var x = (e.clientX - rect.left) / rect.width;
            var y = (e.clientY - rect.top) / rect.height;
            var tiltX = (y - 0.5) * -6;
            var tiltY = (x - 0.5) * 6;
            mock.style.transform =
              "perspective(1200px) rotateX(" + tiltX + "deg) rotateY(" + tiltY + "deg) scale3d(1.02,1.02,1.02)";
          });

          wrap.addEventListener("mouseleave", function () {
            mock.style.transform =
              "perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)";
          });
        })();

        /* ── Mouse-tracking hero glow ── */
        (function () {
          var glow = document.getElementById("heroGlow");
          var hero = document.getElementById("hero");
          if (!glow || !hero) return;

          hero.addEventListener("mousemove", function (e) {
            var rect = hero.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            glow.style.left = x + "px";
            glow.style.top = y + "px";
          });
        })();

        /* ── Count-up animation ── */
        (function () {
          var counters = document.querySelectorAll(".count-up");
          if (!counters.length) return;

          function animateCounter(el) {
            var target = parseInt(el.getAttribute("data-target"), 10);
            var current = 0;
            var duration = 2000;
            var startTime = null;

            function step(timestamp) {
              if (!startTime) startTime = timestamp;
              var progress = Math.min((timestamp - startTime) / duration, 1);
              var eased = 1 - Math.pow(1 - progress, 3);
              current = Math.floor(eased * target);
              el.textContent = current;
              if (progress < 1) {
                requestAnimationFrame(step);
              } else {
                el.textContent = target;
              }
            }

            requestAnimationFrame(step);
          }

          var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });

          counters.forEach(function (el) { obs.observe(el); });
        })();

        /* ── Typing cursor blink (CSS already handles this) ── */

        /* ── Smooth anchor scroll ── */
        (function () {
          document.querySelectorAll('a[href^="#"]').forEach(function (a) {
            a.addEventListener("click", function (e) {
              var id = this.getAttribute("href").slice(1);
              var target = document.getElementById(id);
              if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: "smooth" });
              }
            });
          });
        })();

        console.log("sharp landing · crafted with ✦");
      })();
    </script>
  </body>
</html>
